# ── Vercel Postgres (add via Vercel dashboard → Storage → Create Database) ──
# These are auto-injected when you link a Vercel Postgres DB, but also set them here for local dev
POSTGRES_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."

# ── Admin credentials (set in Vercel dashboard → Settings → Environment Variables) ──
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_this_strong_password_123!"

# ── Session secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
SESSION_SECRET="generate_a_32_byte_hex_string_here_and_keep_it_secret"

# ── Discord webhook (optional) ──
DISCORD_WEBHOOK_URL=""

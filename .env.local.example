# ── Neon Postgres ─────────────────────────────────────────────────────────────
# When you connect a Neon database in the Vercel dashboard, this is auto-injected.
# For local dev, paste your Neon connection string here:
POSTGRES_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# ── Admin credentials ─────────────────────────────────────────────────────────
# Set these in Vercel dashboard → Settings → Environment Variables
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_this_to_something_strong_123!"

# ── Session secret ────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate one:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate_a_32_byte_hex_string_here_and_keep_it_secret_safe"

# ── Discord webhook (optional) ────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=""
